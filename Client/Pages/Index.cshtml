@page
@model IndexModel
@{
    ViewData["Title"] = "Welcome";
}

<section class="hero-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <h1 class="hero-title animate-fade-in">Write your story, share your vision.</h1>
                <p class="hero-subtitle animate-fade-in delay-100">
                    A beautiful, minimal space for your thoughts. Join a community of modern writers and thinkers.
                </p>
                <div class="animate-fade-in delay-200">
                    <a asp-page="/Blog/Index" class="btn-primary-custom text-decoration-none">Explore Latest Posts</a>
                    <a href="#" class="btn btn-link nav-link-custom d-inline-block ms-3">Learn More &rarr;</a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-5">
            <div>
                <h2 class="fw-bold mb-0">Featured Posts</h2>
                <p class="text-muted">Hand-picked stories just for you.</p>
            </div>
            <a asp-page="/Blog/Index" class="text-primary fw-600 text-decoration-none">View all &rarr;</a>
        </div>

        <div class="row g-4">
            @if (Model.FeaturedPosts.Any())
            {
                @foreach (var post in Model.FeaturedPosts)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="blog-card h-100">
                            <a asp-page="/Blog/Details" asp-route-uid="@post.Uid" class="text-decoration-none text-dark">
                                <img src="@(string.IsNullOrEmpty(post.FeaturedImage) ? "https://images.unsplash.com/photo-1516259762381-22954d7d3ad2?q=80&w=2066&auto=format&fit=crop" : post.FeaturedImage)" class="blog-card-img" alt="@post.Title">
                                <div class="blog-card-body">
                                    <span class="blog-category">@(post.Category?.Name ?? "General")</span>
                                    <h3 class="blog-title">@post.Title</h3>
                                    <p class="blog-excerpt">@post.Excerpt</p>
                                    <div class="blog-meta mt-auto">
                                        <img src="https://ui-avatars.com/api/?name=@(post.Author?.Name ?? "Unknown")&background=random" class="blog-author-img" alt="Author">
                                        <div>
                                            <div class="blog-author-name">@(post.Author?.Name ?? "Anonymous")</div>
                                            <div class="blog-date">@post.CreatedAt?.ToString("MMM dd, yyyy")</div>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="text-muted">No posts published yet. Be the first to start the conversation!</p>
                </div>
            }
        </div>
    </div>
</section>

<section class="py-5 bg-white border-top">
    <div class="container text-center py-4">
        <h2 class="fw-bold mb-4">Trusted by creators worldwide</h2>
        <div class="row justify-content-center align-items-center g-5 opacity-50">
            <div class="col-6 col-md-2"><h4>LOGO 1</h4></div>
            <div class="col-6 col-md-2"><h4>LOGO 2</h4></div>
            <div class="col-6 col-md-2"><h4>LOGO 3</h4></div>
            <div class="col-6 col-md-2"><h4>LOGO 4</h4></div>
        </div>
    </div>
</section>
