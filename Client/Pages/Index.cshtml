@page
@model IndexModel
@{
    ViewData["Title"] = "Welcome";
}

<section class="hero-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <h1 class="hero-title animate-fade-in">Write your story, share your vision.</h1>
                <p class="hero-subtitle animate-fade-in delay-100">
                    A beautiful, minimal space for your thoughts. Join a community of modern writers and thinkers.
                </p>
                <div class="animate-fade-in delay-200">
                    <a asp-page="/Blog/Index" class="btn-primary-custom text-decoration-none">Explore Latest Posts</a>
                    <a href="#" class="btn btn-link nav-link-custom d-inline-block ms-3">Learn More &rarr;</a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-5">
            <div>
                <h2 class="fw-bold mb-0">Featured Posts</h2>
                <p class="text-muted">Hand-picked stories just for you.</p>
            </div>
            <a asp-page="/Blog/Index" class="text-primary fw-600 text-decoration-none">View all &rarr;</a>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-lg-4">
                <div class="blog-card">
                    <img src="https://images.unsplash.com/photo-1516259762381-22954d7d3ad2?q=80&w=2066&auto=format&fit=crop" class="blog-card-img" alt="Blog Post">
                    <div class="blog-card-body">
                        <span class="blog-category">Technology</span>
                        <h3 class="blog-title">The Future of AI in Software Development</h3>
                        <p class="blog-excerpt">Explore how artificial intelligence is reshaping the landscape of coding and system architecture in 2026.</p>
                        <div class="blog-meta">
                            <img src="https://ui-avatars.com/api/?name=John+Doe&background=random" class="blog-author-img" alt="Author">
                            <div>
                                <div class="blog-author-name">John Doe</div>
                                <div class="blog-date">March 15, 2026</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="blog-card">
                    <img src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?q=80&w=2072&auto=format&fit=crop" class="blog-card-img" alt="Blog Post">
                    <div class="blog-card-body">
                        <span class="blog-category">Design</span>
                        <h3 class="blog-title">Mastering Modern Web Aesthetics</h3>
                        <p class="blog-excerpt">Why minimalist design and glassmorphism are dominating the web design trends this year.</p>
                        <div class="blog-meta">
                            <img src="https://ui-avatars.com/api/?name=Jane+Smith&background=random" class="blog-author-img" alt="Author">
                            <div>
                                <div class="blog-author-name">Jane Smith</div>
                                <div class="blog-date">March 20, 2026</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="blog-card">
                    <img src="https://images.unsplash.com/photo-1555066931-4365d14bab8c?q=80&w=2070&auto=format&fit=crop" class="blog-card-img" alt="Blog Post">
                    <div class="blog-card-body">
                        <span class="blog-category">Development</span>
                        <h3 class="blog-title">Getting Started with .NET 10</h3>
                        <p class="blog-excerpt">A comprehensive guide to the latest features and performance improvements in the new .NET release.</p>
                        <div class="blog-meta">
                            <img src="https://ui-avatars.com/api/?name=Alex+Johnson&background=random" class="blog-author-img" alt="Author">
                            <div>
                                <div class="blog-author-name">Alex Johnson</div>
                                <div class="blog-date">March 25, 2026</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-white border-top">
    <div class="container text-center py-4">
        <h2 class="fw-bold mb-4">Trusted by creators worldwide</h2>
        <div class="row justify-content-center align-items-center g-5 opacity-50">
            <div class="col-6 col-md-2"><h4>LOGO 1</h4></div>
            <div class="col-6 col-md-2"><h4>LOGO 2</h4></div>
            <div class="col-6 col-md-2"><h4>LOGO 3</h4></div>
            <div class="col-6 col-md-2"><h4>LOGO 4</h4></div>
        </div>
    </div>
</section>
