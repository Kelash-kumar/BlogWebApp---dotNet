<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InkFlow</title>
    
    <!-- Google Fonts - Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Client.styles.css" asp-append-version="true" />
    
    <!-- SweetAlert2 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    
    <style>
        .btn-loading {
            position: relative;
            color: transparent !important;
            pointer-events: none;
        }
        .btn-loading::after {
            content: "";
            position: absolute;
            width: 20px;
            height: 20px;
            top: 50%;
            left: 50%;
            margin-top: -10px;
            margin-left: -10px;
            border: 2px solid rgba(255,255,255,0.3);
            border-top-color: #fff;
            border-radius: 50%;
            animation: btn-spin 0.6s linear infinite;
        }
        @@keyframes btn-spin {
            to { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-custom">
            <div class="container">
                <a class="navbar-brand navbar-brand-custom" asp-area="" asp-page="/Index">
                    Ink<span style="color: var(--secondary-color);">Flow</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-end">
                    <ul class="navbar-nav gap-lg-3">
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-area="" asp-page="/Blog/Index">Blog</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated != true)
                        {
                            <li class="nav-item align-self-center ms-lg-2">
                                 <a class="btn-primary-custom text-decoration-none" asp-page="/Auth/Login">Login</a>
                            </li>
                            <li class="nav-item align-self-center ms-lg-2">
                                 <a class="btn-primary-custom text-decoration-none" asp-page="/Auth/Register">Register</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom" asp-page="/Blog/Create">Create Post</a>
                            </li>
                            <li class="nav-item dropdown ms-lg-3">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 p-0" href="#" id="navbarProfileDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(User.Identity?.Name ?? "User")&background=4f46e5&color=fff" 
                                         class="rounded-circle" style="width: 35px; height: 35px; border: 2px solid var(--white); shadow: var(--shadow-sm);" alt="Profile">
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-lg mt-2 p-2" aria-labelledby="navbarProfileDropdown" style="min-width: 240px;">
                                    <li class="px-3 py-2 border-bottom mb-2">
                                        <div class="fw-bold text-dark">@User.Identity?.Name</div>
                                        <div class="small text-muted">@User.FindFirstValue(System.Security.Claims.ClaimTypes.Email)</div>
                                    </li>
                                    <li><a class="dropdown-item rounded-md py-2" asp-page="/Auth/Profile">My Profile</a></li>
                                    <li><a class="dropdown-item rounded-md py-2" asp-page="/Blog/Index">My Posts</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item rounded-md py-2 text-danger fw-bold" asp-page="/Auth/Logout">
                                            Logout
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer-custom">
        <div class="container text-start">
            <div class="row">
                <div class="col-lg-4 mb-4 mb-lg-0">
                    <span class="footer-brand">Ink<span style="color: var(--secondary-color);">Flow</span></span>
                    <p class="small pe-lg-5">A premium platform for modern writers. Built with ASP.NET Core and a lot of passion for great design.</p>
                </div>
                <div class="col-sm-6 col-lg-2 mb-4 mb-lg-0">
                    <h4 class="footer-heading">Platform</h4>
                    <a class="footer-link" asp-page="/Index">Home</a>
                    <a class="footer-link" asp-page="/Blog/Index">Blog</a>
                    <a class="footer-link" href="#">About Us</a>
                </div>
                <div class="col-sm-6 col-lg-2 mb-4 mb-lg-0">
                    <h4 class="footer-heading">Legal</h4>
                    <a class="footer-link" asp-page="/Privacy">Privacy Policy</a>
                    <a class="footer-link" href="#">Terms of Service</a>
                    <a class="footer-link" href="#">Cookie Policy</a>
                </div>
                <div class="col-lg-4">
                    <h4 class="footer-heading">Subscribe</h4>
                    <p class="small">Get the latest posts delivered straight to your inbox.</p>
                    <div class="input-group mb-3">
                        <input type="text" class="form-control bg-dark border-secondary text-white" placeholder="Email address" aria-label="Email address" style="border-radius: var(--radius-md) 0 0 var(--radius-md);">
                        <button class="btn btn-primary-custom" type="button" style="border-radius: 0 var(--radius-md) var(--radius-md) 0;">Join</button>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                &copy; 2026 Client. All rights reserved.
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
